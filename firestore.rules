rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isMe(uid) { return request.auth.uid == uid; }
    // Replace with your actual admin email:
    function isAdmin() { return request.auth.token.email == "PON_TU_EMAIL_ADMIN_AQUI"; }

    // Users: read by anyone logged in, write only yourself
    match /users/{uid} {
      allow read:  if isAuth();
      allow write: if isAuth() && isMe(uid);
    }

    // Matches: create by any user, update only by players in the match
    match /matches/{matchId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid in resource.data.playerIds;
      allow delete: if false;
    }

    // Notifications: owner reads, anyone can write (to send notifs)
    match /notifications/{uid}/items/{notifId} {
      allow read:  if isAuth() && isMe(uid);
      allow write: if isAuth();
    }

    // Audit: app writes, only admin reads. Never deletable.
    match /audit/{logId} {
      allow create:        if isAuth();
      allow read:          if isAdmin();
      allow update, delete: if false;
    }
  }
}
